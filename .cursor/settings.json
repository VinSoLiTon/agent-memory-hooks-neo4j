{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.cursor/hooks/log_event.cmd\""
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.cursor/hooks/inject_memory.cmd\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.cursor/hooks/log_event.cmd\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.cursor/hooks/log_event.cmd\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.cursor/hooks/log_event.cmd\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.cursor/hooks/log_event.cmd\""
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.cursor/hooks/inject_memory.cmd\""
          }
        ]
      }
    ]
  }
}
